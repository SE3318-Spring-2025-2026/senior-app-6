spring.application.name=spm
spring.datasource.url=jdbc:mysql://localhost:3306/spm
spring.datasource.username=
spring.datasource.password=
spring.jpa.hibernate.ddl-auto=update
spring.jpa.defer-datasource-initialization=true
spring.sql.init.mode=always
jwt.secret=
jwt.expiration=604800000

# AES-256-GCM key for encrypting GitHub PATs and JIRA API tokens at rest (NFR-7).
# Must be a Base64-encoded value that decodes to exactly 32 bytes (256 bits).
# Generate a key with: openssl rand -base64 32
encryption.key=
