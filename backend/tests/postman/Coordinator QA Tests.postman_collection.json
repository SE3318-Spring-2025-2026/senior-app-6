    {
      "name": "Update Rubric - Success (200)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "const jsonData = pm.response.json();\r",
              "\r",
              "pm.test(\"Response is an array of criteria\", function () {\r",
              "    pm.expect(jsonData).to.be.an('array');\r",
              "    pm.expect(jsonData.length).to.eql(2);\r",
              "    pm.expect(jsonData[0].criterionName).to.eql(\"Completeness\");\r",
              "    pm.expect(jsonData[0].gradingType).to.eql(\"Binary\");\r",
              "    pm.expect(Number(jsonData[0].weight)).to.eql(60);\r",
              "    pm.expect(jsonData[1].criterionName).to.eql(\"Code Quality\");\r",
              "    pm.expect(jsonData[1].gradingType).to.eql(\"Soft\");\r",
              "    pm.expect(Number(jsonData[1].weight)).to.eql(40);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
