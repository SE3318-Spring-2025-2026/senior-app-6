    {
      "name": "Auth",
      "item": [
        {
          "name": "Login Success",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "const jsonData = pm.response.json();\r",
                  "\r",
                  "pm.environment.set(\"adminToken\", jsonData.token);\r",
                  "pm.environment.set(\"bearerToken\", jsonData.token);\r",
                  "\r",
                  "pm.test(\"User role is Admin\", function () {\r",
                  "    pm.expect(jsonData.userInfo.role).to.eql(\"Admin\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
